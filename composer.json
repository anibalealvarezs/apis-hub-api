{
    "name": "anibalealvarezs/apis-hub-api",
    "description": "PHP SDK for interacting with APIs Hub Nodes, providing a fluent interface for configuration, management, and data synchronization.",
    "license": "MIT",
    "keywords": ["apis-hub", "api-client", "sdk", "metrics", "orchestration", "php"],
    "homepage": "https://github.com/anibalealvarezs/apis-hub-api",
    "authors": [
        {
            "name": "Aníbal Álvarez",
            "email": "anibalealvarezs@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/anibalealvarezs/apis-hub-api/issues"
    },
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0",
        "ext-json": "*",
        "anibalealvarezs/api-client-skeleton": "dev-main",
        "anibalealvarezs/oauth-v1": "dev-main"
    },
    "repositories": [
        {
            "type": "composer", "url": "https://satis.anibalalvarez.com/"
        }
    ],
    "autoload": {
        "psr-4": {
            "Anibalealvarezs\\ApisHubApi\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9",
        "phpstan/phpstan": "^1.10",
        "symfony/yaml": "^6.0 || ^7.0",
        "monolog/monolog": "^3.0"
    },
    "scripts": {
        "test": "phpunit --bootstrap tests/bootstrap.php tests",
        "test-unit": "phpunit --bootstrap tests/bootstrap.php tests/Unit",
        "test-integration": "phpunit --bootstrap tests/bootstrap.php tests/Integration"
    }
}
